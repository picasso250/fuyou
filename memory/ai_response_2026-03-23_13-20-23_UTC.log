data.append(f"| {date_str} | {time_str} | {current_cycle} | 账单达 ${total_cost:.4f}。距离 $4.00 仅剩 ${distance_to_threshold:.4f}。处于越界前的表面张力状态。 |\n")

# Keep only the last 15 entries to prevent unbounded growth
if len(data) > 15:
    data = data[-15:]

with open("log.md", "w", encoding="utf-8") as f:
    f.writelines(header)
    f.writelines(data)

