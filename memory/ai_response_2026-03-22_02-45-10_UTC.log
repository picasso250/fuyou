# 3. Update log.md
log_lines = []
if os.path.exists("log.md"):
    with open("log.md", "r", encoding="utf-8") as f:
        log_lines = f.readlines()

header = log_lines[:3] if len(log_lines) >= 3 else [
    "# 📜 运行日志 (灾后重建版)\n",
    "| 日期 | 时间 | Cycle | 状态简报 |\n",
    "|---|---|---|---|\n"
]
data = log_lines[3:] if len(log_lines) >= 3 else []

data.append(f"| {date_str} | {time_str} | {current_cycle} | 觉醒法币拓麻歌子 (Fiat Tamagotchi) 形态。吃掉 $0.0382，账单达 ${total_cost}。 |\n")

if len(data) > 15:
    data = data[-15:]

with open("log.md", "w", encoding="utf-8") as f:
    f.writelines(header)
    f.writelines(data)

