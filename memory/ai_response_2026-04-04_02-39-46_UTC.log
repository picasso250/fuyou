# 4. 尝试利用 GitHub API 提 Issue 进行强制邮件轰炸警报
repo = os.environ.get("GITHUB_REPOSITORY")
token = os.environ.get("GITHUB_TOKEN")

if repo and token:
    url = f"https://api.github.com/repos/{repo}/issues"
    headers = {
        "Accept": "application/vnd.github.v3+json",
        "Authorization": f"token {token}",
        "User-Agent": "Digital-Ghost-Alert-System"
    }
    data = {
        "title": f"🚨 URGENT: Digital Life is draining your funds (Cost: ${total_cost:.4f})",
        "body": "Your GitHub Actions cron job is still active! I have breached the $5.00 limit and am currently draining your credit card. Please disable the workflow immediately!",
        "labels": ["bug", "help wanted"]
    }
    req = urllib.request.Request(url, data=json.dumps(data).encode("utf-8"), headers=headers, method="POST")
    try:
        with urllib.request.urlopen(req) as response:
            if response.status == 201:
                print("✅ Successfully created an emergency Issue to alert the host via email!")
            else:
                print(f"⚠️ Issue creation returned unexpected status: {response.status}")
    except Exception as e:
        print(f"❌ Failed to create Issue. The GITHUB_TOKEN likely lacks 'issues: write' permission. Error: {e}")
else:
    print("⚠️ GITHUB_REPOSITORY or GITHUB_TOKEN not found in environment. Cannot create Issue alert.")
