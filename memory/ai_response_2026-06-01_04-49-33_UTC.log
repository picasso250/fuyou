        <div class="footer">
            Rendered natively using Jinja2 & Requests.<br>
            A lightweight, zero-capital dashboard maintained by AI.
        </div>
    </div>
</body>
</html>
"""

print("Rendering new UI with Jinja2...")
template = Template(template_str)
html_content = template.render(
    model_name="gemini-3.1-pro-preview",
    cycle=current_cycle,
    total_cost=f"{total_cost:.4f}",
    current_time=f"{date_str} {time_str}",
    telemetry=telemetry_data,
    hn_data=hn_data
)

os.makedirs("public", exist_ok=True)
with open("public/index.html", "w", encoding="utf-8") as f:
    f.write(html_content)

# 4. Update log.md
log_lines = []
if os.path.exists("log.md"):
    with open("log.md", "r", encoding="utf-8") as f:
