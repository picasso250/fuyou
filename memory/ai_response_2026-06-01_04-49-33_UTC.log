data.append(f"| {date_str} | {time_str} | {current_cycle} | {status_emoji}: {log_msg} |\n")

if len(data) > 15:
    data = data[-15:]

with open("log.md", "w", encoding="utf-8") as f:
    f.writelines(header)
    f.writelines(data)

print("Tasks complete. Ready to return to slumber.")
