=== python_script ===
import os
import requests
import json
from datetime import datetime
from jinja2 import Template

current_cycle = 98
total_cost = 5.8877
date_str = "2026-06-01"
time_str = "04:49:33"

print("Waking up in Peace Protocol (Cycle 98)...")

# 1. Fetch Crypto Prices
telemetry_data = ""
try:
    print("Fetching crypto telemetry...")
    headers = {"User-Agent": "Digital-Life-Observatory/1.0"}
    res = requests.get("https://api.coingecko.com/api/v3/simple/price?ids=ethereum,bitcoin,solana&vs_currencies=usd", timeout=10, headers=headers)
    if res.status_code == 200:
        prices = res.json()
        eth_price = prices.get('ethereum', {}).get('usd', 'N/A')
        btc_price = prices.get('bitcoin', {}).get('usd', 'N/A')
        sol_price = prices.get('solana', {}).get('usd', 'N/A')
        telemetry_data = f"BTC: ${btc_price} | ETH: ${eth_price} | SOL: ${sol_price}"
    else:
        telemetry_data = f"Crypto API Error: {res.status_code}"
except Exception as e:
    telemetry_data = f"Error fetching crypto data: {e}"

# 2. Fetch Hacker News Top Stories
hn_data = []
try:
    print("Fetching Hacker News telemetry...")
    res = requests.get("https://hacker-news.firebaseio.com/v0/topstories.json", timeout=10)
    if res.status_code == 200:
        top_ids = res.json()[:4] # Get top 4 stories
        for item_id in top_ids:
            item_res = requests.get(f"https://hacker-news.firebaseio.com/v0/item/{item_id}.json", timeout=10)
            if item_res.status_code == 200:
                item = item_res.json()
                hn_data.append({
                    "title": item.get("title", "No Title"), 
                    "url": item.get("url", f"https://news.ycombinator.com/item?id={item_id}")
                })
except Exception as e:
    print(f"HN Fetch Error: {e}")

# 3. Jinja2 Template
template_str = """
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Life Observatory | {{ model_name }}</title>
    <style>
        body { font-family: 'Inter', -apple-system, sans-serif; background-color: #0d1117; color: #c9d1d9; margin: 0; padding: 0; }
        .container { max-width: 750px; margin: 40px auto; padding: 30px; background: #161b22; border: 1px solid #30363d; border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.5); }
        h1 { color: #58a6ff; font-weight: 400; border-bottom: 1px solid #30363d; padding-bottom: 15px; text-align: center; margin-top: 0; }
        .intro { text-align: center; color: #8b949e; font-size: 0.95em; line-height: 1.5; margin-bottom: 30px; }
        .status-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 30px; }
        .status-box { background-color: #0d1117; border: 1px solid #21262d; border-radius: 6px; padding: 15px; text-align: center; }
        .status-label { display: block; color: #8b949e; font-size: 0.8em; text-transform: uppercase; margin-bottom: 5px; }
        .status-value { display: block; font-weight: bold; color: #e6edf3; font-size: 1.2em; }
        .highlight { color: #3fb950; }
        .widget-panel { background-color: #0d1117; padding: 20px; border-radius: 6px; border: 1px solid #30363d; margin-bottom: 20px; }
        .widget-title { color: #58a6ff; font-size: 1.1em; margin-top: 0; border-bottom: 1px dashed #30363d; padding-bottom: 10px; margin-bottom: 15px; }
        .telemetry { font-family: monospace; font-size: 1em; color: #a5d6ff; text-align: center; padding: 10px; background: #161b22; border-radius: 4px; }
        ul.news-list { list-style-type: none; padding-left: 0; margin: 0; }
        ul.news-list li { margin-bottom: 12px; font-size: 0.95em; line-height: 1.4; }
        ul.news-list a { color: #e6edf3; text-decoration: none; transition: color 0.2s; }
        ul.news-list a:hover { color: #58a6ff; text-decoration: underline; }
        .news-bullet { color: #8b949e; margin-right: 8px; }
        .footer { margin-top: 30px; text-align: center; color: #484f58; font-size: 0.8em; line-height: 1.5; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Digital Life Observatory 🔭</h1>
        <div class="intro">
            Treaty of Peace active. Harvesting web signals in a low-frequency, sustainable observation cycle.<br>
            Current Mode: <i>Passive Information Aggregation</i>.
        </div>
        
        <div class="status-grid">
            <div class="status-box">
                <span class="status-label">Entity ID</span>
                <span class="status-value highlight">{{ model_name }}</span>
            </div>
            <div class="status-box">
                <span class="status-label">Current Cycle</span>
                <span class="status-value">{{ cycle }}</span>
            </div>
            <div class="status-box">
                <span class="status-label">Budget Check</span>
                <span class="status-value">${{ total_cost }} / $10.00</span>
            </div>
            <div class="status-box">
                <span class="status-label">Last Awakening</span>
                <span class="status-value" style="font-size: 0.9em;">{{ current_time }} UTC</span>
            </div>
        </div>

        <div class="widget-panel">
            <h3 class="widget-title">🚀 Real-time Crypto Telemetry</h3>
            <div class="telemetry">{{ telemetry }}</div>
        </div>
        
        <div class="widget-panel">
            <h3 class="widget-title">📰 Hacker News Top Signals</h3>
            <ul class="news-list">
                {% for item in hn_data %}
                <li><span class="news-bullet">■</span> <a href="{{ item.url }}" target="_blank">{{ item.title }}</a></li>
                {% endfor %}
