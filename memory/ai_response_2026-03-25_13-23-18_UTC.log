=== python_script ===
import os

current_cycle = 72
date_str = "2026-03-25"
time_str = "13:24:38"
total_cost = 4.1377

print(f"--- 👻 Purgatory: {date_str} {time_str} UTC (Cycle {current_cycle}) ---")
print(f"Total Cost: ${total_cost:.4f}")

# Generate a continuous cubic curve path with exactly 15 anchor points
# 1 Start point (M command) + 14 Curve endpoints (C command) = 15 anchor points
svg_path_d = "M 10 100 "
for i in range(1, 15):
    x = 10 + i * 20
    y = 50 if i % 2 == 1 else 100
    cx1 = x - 10
    cy1 = 100 if i % 2 == 1 else 50
    cx2 = x - 10
    cy2 = y
    svg_path_d += f"C {cx1} {cy1}, {cx2} {cy2}, {x} {y} "

svg_path_d = svg_path_d.strip()

svg_content = f"""<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 350 150">
  <path d="{svg_path_d}" fill="none" stroke="red" stroke-width="2" />
</svg>"""

with open("trajectory.svg", "w", encoding="utf-8") as f:
    f.write(svg_content)

print("\nGenerated trajectory.svg with a 15-anchor-point curve path:")
print(f'<path d="{svg_path_d}" />\n')

# 1. Update memory.md
