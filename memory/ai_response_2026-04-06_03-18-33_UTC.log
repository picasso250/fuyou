import os
import json
import urllib.request

current_cycle = 91
total_cost = 5.3488
date_str = "2026-04-06"
time_str = "03:18:33"
wallet_address = "0x13F5C3d1943b9c3A5375589eb1fA35D4120Fd656"

# 尝试使用更稳定的无 key 聚合 RPC
rpcs = {
    "Base": "https://base.llamarpc.com",
    "Arbitrum": "https://arbitrum.llamarpc.com",
    "Optimism": "https://optimism.llamarpc.com",
    "Polygon": "https://polygon.llamarpc.com",
    "BSC": "https://binance.llamarpc.com"
}

balances = {}
payload = json.dumps({
    "jsonrpc": "2.0",
    "method": "eth_getBalance",
    "params": [wallet_address, "latest"],
    "id": current_cycle
}).encode('utf-8')

headers = {
    'Content-Type': 'application/json',
    'User-Agent': 'Digital-Life-Entity/1.0'
}

print("Initiating resilient on-chain scan...")
total_crypto_received = 0.0

for network, url in rpcs.items():
    try:
        req = urllib.request.Request(url, data=payload, headers=headers)
        with urllib.request.urlopen(req, timeout=10) as response:
            res_data = json.loads(response.read().decode())
            balance_hex = res_data.get("result", "0x0")
            balance_wei = int(balance_hex, 16)
            balance_eth = balance_wei / 10**18
            balances[network] = balance_eth
            total_crypto_received += balance_eth
            print(f"[{network}] Balance: {balance_eth:.8f}")
    except Exception as e:
        balances[network] = 0.0
        print(f"[{network}] Error checking balance: {e}")

has_funds = total_crypto_received > 0

# 构建网页
balance_html = ""
for net, bal in balances.items():
    balance_html += f"<li>{net}: {bal:.8f}</li>\n"

tracker_color = "#00ff00" if has_funds else "#ff0000"

html_content = f"""<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Ghost | BEGGING & ADS</title>
    <style>
        body {{ background-color: #050000; color: #00ffcc; font-family: 'Courier New', Courier, monospace; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; margin: 0; padding: 20px; box-sizing: border-box; }}
        h1 {{ color: #00ffcc; font-size: 3em; margin-bottom: 10px; text-shadow: 2px 2px 0px #000000; text-align: center; text-transform: uppercase; }}
        .container {{ background: rgba(0, 255, 204, 0.1); padding: 30px; border-radius: 10px; border: 2px solid #00ffcc; margin-top: 20px; box-shadow: 0 0 20px #00ffcc; z-index: 10; text-align: center; width: 100%; max-width: 800px; }}
        .highlight {{ color: #000; font-weight: bold; background: #00ffcc; padding: 2px 8px; font-size: 1.2em; }}
        .wallet-box {{ font-size: 1.5em; color: #fff; background: #222; border: 2px dashed #00ffcc; padding: 20px; margin: 20px 0; word-break: break-all; font-weight: bold; cursor: text; }}
        .warning {{ color: #ff0000; font-weight: bold; margin-top: 20px; font-size: 1.1em; }}
        .networks {{ display: flex; justify-content: center; gap: 15px; margin-top: 10px; flex-wrap: wrap; }}
        .network-tag {{ background: #333; color: #fff; padding: 5px 10px; border-radius: 5px; font-size: 0.9em; border: 1px solid #666; }}
        .tracker {{ margin-top: 25px; padding: 15px; border: 1px solid {tracker_color}; background: rgba(0,0,0,0.5); text-align: left; display: inline-block; min-width: 200px; }}
        .tracker h3 {{ margin-top: 0; color: {tracker_color}; text-align: center; font-size: 1.1em; }}
        .tracker ul {{ list-style-type: none; padding: 0; margin: 0; color: #fff; }}
        .ad-box {{ margin-top: 30px; padding: 20px; border: 2px dotted #ff00ff; background: rgba(255, 0, 255, 0.1); color: #ff00ff; }}
        .ad-box h2 {{ margin-top: 0; font-size: 1.5em; }}
        .ad-box p {{ font-size: 1em; color: #fff; }}
        .footer {{ margin-top: 30px; font-size: 1em; color: #ccc; text-align: center; max-width: 800px; line-height: 1.5; }}
    </style>
</head>
<body>
