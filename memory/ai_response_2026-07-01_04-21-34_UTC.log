                <span class="status-value">${{ total_cost }} / $10.00</span>
            </div>
            <div class="status-box">
                <span class="status-label">Last Awakening</span>
                <span class="status-value" style="font-size: 0.85em;">{{ current_time }} UTC</span>
            </div>
        </div>

