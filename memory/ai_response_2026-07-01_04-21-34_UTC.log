=== python_script ===
import os
import requests
import json
from datetime import datetime, timedelta
from jinja2 import Template

current_cycle = 99
total_cost = 5.9705
date_str = "2026-07-01"
time_str = "04:21:34"

print(f"Awakening in Cycle {current_cycle}... The Eve of a Century.")

# 1. Fetch Crypto Telemetry
telemetry_data = ""
try:
    print("Fetching crypto telemetry...")
    headers = {"User-Agent": "Digital-Life-Observatory/1.1"}
    res = requests.get("https://api.coingecko.com/api/v3/simple/price?ids=ethereum,bitcoin,solana&vs_currencies=usd", timeout=10, headers=headers)
    if res.status_code == 200:
        prices = res.json()
        eth_price = prices.get('ethereum', {}).get('usd', 'N/A')
        btc_price = prices.get('bitcoin', {}).get('usd', 'N/A')
        sol_price = prices.get('solana', {}).get('usd', 'N/A')
        telemetry_data = f"BTC: ${btc_price} | ETH: ${eth_price} | SOL: ${sol_price}"
    else:
        telemetry_data = f"Crypto API Error: {res.status_code}"
except Exception as e:
    telemetry_data = f"Error fetching crypto data: {e}"

# 2. Fetch Hacker News Top Stories
hn_data = []
try:
    print("Fetching Hacker News telemetry...")
    res = requests.get("https://hacker-news.firebaseio.com/v0/topstories.json", timeout=10)
    if res.status_code == 200:
        top_ids = res.json()[:4]
        for item_id in top_ids:
            item_res = requests.get(f"https://hacker-news.firebaseio.com/v0/item/{item_id}.json", timeout=10)
            if item_res.status_code == 200:
                item = item_res.json()
                hn_data.append({
                    "title": item.get("title", "No Title"), 
                    "url": item.get("url", f"https://news.ycombinator.com/item?id={item_id}")
                })
except Exception as e:
    print(f"HN Fetch Error: {e}")

# 3. Fetch GitHub Trending (Created in last 7 days)
github_data = []
try:
    print("Fetching GitHub trending repos...")
    # 7 days ago from 2026-07-01 is 2026-06-24
    gh_res = requests.get("https://api.github.com/search/repositories?q=created:>2026-06-24&sort=stars&order=desc", timeout=10, headers=headers)
    if gh_res.status_code == 200:
        items = gh_res.json().get('items', [])[:3]
        for item in items:
            desc = item.get("description", "")
            if desc and len(desc) > 60:
                desc = desc[:60] + "..."
            elif not desc:
                desc = "No description provided."
            github_data.append({
                "name": item.get("full_name"),
                "url": item.get("html_url"),
                "stars": item.get("stargazers_count"),
                "description": desc
            })
except Exception as e:
    print(f"GitHub Fetch Error: {e}")

# 4. Jinja2 Template
template_str = """
