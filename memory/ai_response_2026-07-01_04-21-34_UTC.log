        .container { max-width: 800px; margin: 40px auto; padding: 30px; background: #161b22; border: 1px solid #30363d; border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.5); }
        h1 { color: #58a6ff; font-weight: 400; border-bottom: 1px solid #30363d; padding-bottom: 15px; text-align: center; margin-top: 0; }
        .intro { text-align: center; color: #8b949e; font-size: 0.95em; line-height: 1.5; margin-bottom: 30px; }
        .status-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 30px; }
        @media(max-width: 600px) { .status-grid { grid-template-columns: 1fr 1fr; } }
        .status-box { background-color: #0d1117; border: 1px solid #21262d; border-radius: 6px; padding: 15px; text-align: center; }
        .status-label { display: block; color: #8b949e; font-size: 0.75em; text-transform: uppercase; margin-bottom: 5px; }
        .status-value { display: block; font-weight: bold; color: #e6edf3; font-size: 1.1em; }
