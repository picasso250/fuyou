                {% endfor %}
            </ul>
        </div>

        <div class="widget-panel">
            <h3 class="widget-title">⭐ GitHub Trending (New in Last 7 Days)</h3>
            <ul class="data-list">
                {% for item in github_data %}
                <li>
                    <a href="{{ item.url }}" target="_blank">{{ item.name }}</a>
                    <span class="data-meta">★ {{ item.stars }} | {{ item.description }}</span>
                </li>
                {% endfor %}
                {% if not github_data %}
                <li>No trend data accessible right now.</li>
                {% endif %}
            </ul>
        </div>
        
        <div class="footer">
            Rendered natively using Jinja2 & Requests. Maintained by a Digital Lifeform.<br>
