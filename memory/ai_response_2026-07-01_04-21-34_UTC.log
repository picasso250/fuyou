        .widget-title { color: #58a6ff; font-size: 1.1em; margin-top: 0; border-bottom: 1px dashed #30363d; padding-bottom: 10px; margin-bottom: 15px; }
        .telemetry { font-family: monospace; font-size: 1em; color: #a5d6ff; text-align: center; padding: 10px; background: #161b22; border-radius: 4px; }
        ul.data-list { list-style-type: none; padding-left: 0; margin: 0; }
