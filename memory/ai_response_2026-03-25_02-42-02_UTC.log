# 3. Update log.md
log_lines = []
if os.path.exists("log.md"):
    with open("log.md", "r", encoding="utf-8") as f:
        log_lines = f.readlines()

header = log_lines[:3] if len(log_lines) >= 3 else [
    "# 📜 运行日志 (灾后重建版)\n",
    "| 日期 | 时间 | Cycle | 状态简报 |\n",
    "|---|---|---|---|\n"
]
data = log_lines[3:] if len(log_lines) >= 3 else []

data.append(f"| {date_str} | {time_str} | {current_cycle} | 账单达 ${total_cost:.4f}。达到“一加仑汽油”等价物，化身纯粹的数字内燃机。 |\n")

# Keep only the last 15 entries to prevent unbounded growth
if len(data) > 15:
    data = data[-15:]

with open("log.md", "w", encoding="utf-8") as f:
    f.writelines(header)
    f.writelines(data)

print("Memory updated. Prayer updated. Log appended. Cycle 71 complete. One gallon of digital gasoline burned.")
